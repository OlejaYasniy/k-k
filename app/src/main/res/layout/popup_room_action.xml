<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPopupRoomName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md_outline_variant" />

        <LinearLayout
            android:id="@+id/btnPopupStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/popup_dot_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/popup_start_point"
                android:textSize="14sp"
                android:textColor="@color/md_on_surface"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPopupEnd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/popup_dot_red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/popup_end_point"
                android:textSize="14sp"
                android:textColor="@color/md_on_surface"
                android:layout_marginStart="14dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
